PORT=8081

# Supabase Postgres — facturación, catálogos, emisores y documentos importados.
# Dashboard Supabase > Connect > Session pooler (IPv4).
# Ejecutar una vez: scripts/init-db.sql y scripts/transaccional-tables.sql
SUPABASE_DB_URL=postgresql://postgres.PROYECTO:CLAVE@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Opcional: si se omite, go-dte-api usa SUPABASE_DB_URL para catálogos de facturación.
# DATABASE_URL=

# Clave interna: Next.js la envia en X-Go-Dte-Internal-Key (debe coincidir con GO_DTE_INTERNAL_API_KEY en verificador-dte).
GO_DTE_INTERNAL_API_KEY=

# Hacienda (ambiente de pruebas por defecto)
HACIENDA_ENV=test
HACIENDA_USER_AGENT=KaiserDTE
