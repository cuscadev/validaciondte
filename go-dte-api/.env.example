PORT=8081

# Supabase Postgres — facturación, catálogos, emisores y documentos importados.
# Dashboard Supabase > Connect > Session pooler (IPv4).
# Ejecutar una vez: scripts/init-db.sql y scripts/transaccional-tables.sql
SUPABASE_DB_URL=postgresql://postgres.PROYECTO:CLAVE@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Opcional: si se omite, go-dte-api usa SUPABASE_DB_URL para catálogos de facturación.
# DATABASE_URL=

# Clave interna: Next.js la envia en X-Go-Dte-Internal-Key (debe coincidir con GO_DTE_INTERNAL_API_KEY en verificador-dte).
GO_DTE_INTERNAL_API_KEY=

# Hacienda (ambiente de pruebas por defecto)
HACIENDA_ENV=test
HACIENDA_USER_AGENT=KaiserDTE
HACIENDA_AUTH_URL_TEST=https://apitest.dtes.mh.gob.sv/seguridad/auth
HACIENDA_AUTH_URL_PROD=https://api.dtes.mh.gob.sv/seguridad/auth
HACIENDA_CREDENTIALS_ENCRYPTION_KEY=
HACIENDA_CERTIFICATE_CACHE_TTL=3600

# Supabase Storage para certificados .crt (bucket privado).
# Si SUPABASE_SERVICE_ROLE_KEY esta vacio, el certificado se guarda cifrado en Postgres (certificado_xml_cifrado).
# SUPABASE_URL se infiere de SUPABASE_DB_URL si se omite.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CERTIFICATES_BUCKET=certificates

# Obligatorio para cifrar passwordPri y certificados en Postgres (minimo 16 caracteres).
HACIENDA_CREDENTIALS_ENCRYPTION_KEY=

# Fallback local opcional (archivos .crt en disco)
HACIENDA_CERTIFICATE_HOME=
