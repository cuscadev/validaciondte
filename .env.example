# Unico archivo de entorno del repo: copia a .env.local en esta misma carpeta (raiz).
# cp .env.example .env.local   (Linux/macOS)
# Copy-Item .env.example .env.local   (PowerShell)
#
# Next.js (verificador-dte/) y scripts (supabase/, scripts/) leen este .env.local.

# --- Firebase cliente (Firebase Console > Project settings > General) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (Service accounts > Generate new private key) ---
# Opción A: JSON completo en una línea
FIREBASE_SERVICE_ACCOUNT_JSON=

# Opción B: variables sueltas (si no usas FIREBASE_SERVICE_ACCOUNT_JSON)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# --- Sesión API (genera uno aleatorio, mín. 32 caracteres) ---
JWT_SECRET=

# --- API Go (proxy server-side de Next.js) ---
# Local (go run ./cmd/api en go-dte-api):
GO_DTE_API_URL=http://127.0.0.1:8081
# Clave compartida Next.js -> go-dte-api (email sync, min. 32 caracteres aleatorios)
GO_DTE_INTERNAL_API_KEY=
# Render / producción:
# GO_DTE_API_URL=https://validaciondte.onrender.com

# --- Hacienda ---
HACIENDA_ENV=test
HACIENDA_USER_AGENT=KaiserDTE

# --- Opcionales ---
# TOTP_ENCRYPTION_KEY=
# BLOB_READ_WRITE_TOKEN=
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# GO_DTE_DEFAULT_CONCURRENCY=8

# --- Supabase (importacion DTE desde correo IMAP) ---
# Las tres variables deben apuntar al MISMO proyecto (mismo ref en la URL).
NEXT_PUBLIC_SUPABASE_URL=
# Secret key (sb_secret_...) o legacy service_role JWT — solo servidor.
SUPABASE_SERVICE_ROLE_KEY=
# Alias opcional:
# SUPABASE_SECRET_KEY=
# Postgres directo (migraciones: node supabase/apply-migration.mjs; go-dte-api email sync)
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Alias opcional para go-dte-api:
# DATABASE_URL=
# Genera 32 bytes en base64: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
EMAIL_CREDENTIALS_ENCRYPTION_KEY=
# Concurrencia IMAP en go-dte-api (opcional, default 8)
# GO_EMAIL_SYNC_CONCURRENCY=8
# GO_EMAIL_MESSAGES_PER_BATCH=50
# Legacy alias (opcional): GOOGLE_TOKEN_ENCRYPTION_KEY=

# --- Microsoft OAuth (IMAP Outlook / Microsoft 365) ---
# Azure Portal > App registrations > New registration
# - Supported accounts: personal + work/school
# - Redirect URI (Web): {NEXT_PUBLIC_APP_URL}/api/integrations/email/microsoft/callback
# - API permissions (delegated): IMAP.AccessAsUser.All (Office 365 Exchange Online),
#   offline_access, openid, profile, email
# - Certificates & secrets: client secret
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Default "common" permite cuentas @outlook.com y Microsoft 365
MICROSOFT_TENANT_ID=common
# Opcional; default: {NEXT_PUBLIC_APP_URL}/api/integrations/email/microsoft/callback
# MICROSOFT_OAUTH_REDIRECT_URI=
